{
  "name": "Message",
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Reference to session"
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "assistant",
        "system"
      ]
    },
    "content": {
      "type": "string"
    }
  },
  "required": [
    "session_id",
    "role",
    "content"
  ]
}